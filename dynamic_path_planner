        # You mentioned starting at roughly 0,0,0
        start_node = (0, 0, 0) 
        
        # Reads the incoming goal topic and converts to grid coordinates
        goal_x = int(round(msg.pose.position.x / self.resolution))
        goal_y = int(round(msg.pose.position.y / self.resolution))
        goal_z = int(round(msg.pose.position.z / self.resolution))
        goal_node = (goal_x, goal_y, goal_z)
        
        # Execute the math
        path_nodes = self.a_star_search(start_node, goal_node)
        
        if path_nodes:
            self.publish_path(path_nodes)

    def publish_path(self, path_nodes):
        ros_path = Path()
        ros_path.header.frame_id = "world"
        ros_path.header.stamp = rospy.Time.now()
        
        for node in path_nodes:
            pose = PoseStamped()
            pose.header.frame_id = "world"
            pose.pose.position.x = node[0] * self.resolution
            pose.pose.position.y = node[1] * self.resolution
            pose.pose.position.z = node[2] * self.resolution
            ros_path.poses.append(pose)
            
        self.path_pub.publish(ros_path)

